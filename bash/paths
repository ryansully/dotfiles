#!/usr/bin/env bash

# home and local bin
[ -d $HOME/bin ] && PATH="$HOME/bin:$PATH"
[ -d $HOME/.local/bin ] && PATH="$HOME/.local/bin:$PATH"

# NPM path
[ -d $HOME/.npm-packages/bin ] && PATH="$HOME/.npm-packages/bin:$PATH"
export NODE_PATH=$NODE_PATH:$HOME/.npm-packages/lib/node_modules

# pyenv path
[ -d $HOME/.pyenv/bin ] && PATH="$HOME/.pyenv/bin:$PATH"

# rbenv path
[ -d $HOME/.rbenv/bin ] && PATH="$HOME/.rbenv/bin:$PATH"

# Android SDK
[ -d $HOME/Development/adt-bundle-linux-x86_64/sdk ] && export PATH="${PATH}:$HOME/Development/adt-bundle-linux-x86_64/sdk/tools:$HOME/Development/adt-bundle-linux-x86_64/sdk/platform-tools"

if [ `uname` = "Darwin" ]; then
    PYTHON2_VERSION=$(python -c 'import sys; print(".".join(map(str, sys.version_info[:2])))')
    PYTHON3_VERSION=$(python3 -c 'import sys; print(".".join(map(str, sys.version_info[:2])))')
    [ -d "$HOME/Library/Python/$PYTHON2_VERSION/bin" ] && PATH="$HOME/Library/Python/$PYTHON2_VERSION/bin:$PATH"
    [ -d "$HOME/Library/Python/$PYTHON3_VERSION/bin" ] && PATH="$HOME/Library/Python/$PYTHON3_VERSION/bin:$PATH"
fi
